# Copy this file to .env and adjust values as needed

# Server port
PORT=3000

# Milliseconds to wait between paginated requests (prevents rate-limiting)
REQUEST_DELAY_MS=800

# Max retry attempts on failed requests (uses exponential backoff)
MAX_RETRIES=3

# Max log lines kept in memory per scrape session
MAX_LOG_LINES=500

# Set to true to run Forgiato's Chromium in headless mode (only works if Cloudflare isn't blocking)
FORGIATO_HEADLESS=false

# Limit Forgiato scrape to N wheels (0 = no limit, scrapes all)
FORGIATO_LIMIT=0
